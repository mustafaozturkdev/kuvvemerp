{
  "name": "@kuvvem/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./master-client": "./src/master-client.ts",
    "./tenant-client": "./src/tenant-client.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate --schema=./prisma/schema.master.prisma && prisma generate --schema=./prisma/schema.tenant.prisma",
    "prisma:migrate:master": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.master.prisma",
    "prisma:migrate:tenant": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.tenant.prisma",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema=./prisma/schema.master.prisma",
    "prisma:status": "dotenv -e ../../.env -- prisma migrate status --schema=./prisma/schema.master.prisma",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
