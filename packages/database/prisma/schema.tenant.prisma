// ============================================================
// KUVVEM v2 — TENANT DATABASE (KOMPLE 16 MODUL)
// ============================================================
// Her tenant kendi DB'sinde. Bu sema template.
// Kaynak: temp/v2/03-veritabani/01..16-*.sql
// Toplam: ~170 model, 16 modul
// ============================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client-tenant"
  previewFeatures = ["multiSchema", "postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL_TENANT_TEMPLATE")
  extensions = [pgcrypto, pg_trgm, citext, ltree, unaccent]
}

// ================================================================
// MODUL 01 — SISTEM
// ================================================================

model SistemAyar {
  id                      Int       @id @default(1)
  tenantId                String    @map("tenant_id") @db.Uuid
  firmaAdi                String    @map("firma_adi") @db.VarChar(200)
  firmaLogoUrl            String?   @map("firma_logo_url") @db.Text
  firmaFaviconUrl         String?   @map("firma_favicon_url") @db.Text
  varsayilanDil           String    @default("tr") @map("varsayilan_dil") @db.Char(2)
  desteklenenDiller       String[]  @default(["tr", "en"]) @map("desteklenen_diller")
  varsayilanParaBirimi    String    @default("TRY") @map("varsayilan_para_birimi") @db.Char(3)
  zamanDilimi             String    @default("Europe/Istanbul") @map("zaman_dilimi") @db.VarChar(50)
  ulkeKodu                String    @default("TR") @map("ulke_kodu") @db.Char(2)
  tarihFormati            String    @default("DD.MM.YYYY") @map("tarih_formati") @db.VarChar(20)
  saatFormati             String    @default("HH:mm") @map("saat_formati") @db.VarChar(10)
  haftaningunuBaslangic   Int       @default(1) @map("haftaningunu_baslangic") @db.SmallInt
  tema                    String    @default("sistem") @db.VarChar(20)
  markaRengi              String?   @map("marka_rengi") @db.VarChar(20)
  moduller                Json      @default("{}") @db.JsonB
  numaraSerileri          Json      @default("{}") @map("numara_serileri") @db.JsonB
  eFaturaAyar             Json      @default("{}") @map("e_fatura_ayar") @db.JsonB
  bildirimAyar            Json      @default("{}") @map("bildirim_ayar") @db.JsonB
  varsayilanKurKaynagiId  BigInt?   @map("varsayilan_kur_kaynagi_id")
  veriSaklamaYili         Int       @default(10) @map("veri_saklama_yili")
  olusturmaTarihi         DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi        DateTime  @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  varsayilanKurKaynagi DovizKuruKaynak? @relation(fields: [varsayilanKurKaynagiId], references: [id], onDelete: Restrict)

  @@map("sistem_ayar")
}

model SistemAyarVersiyon {
  id                    BigInt   @id @default(autoincrement())
  versiyonNo            Int      @map("versiyon_no")
  oncekiAyar            Json     @map("onceki_ayar") @db.JsonB
  yeniAyar              Json     @map("yeni_ayar") @db.JsonB
  degisimAlanlari       String[] @map("degisim_alanlari")
  aciklama              String?  @db.Text
  olusturanKullaniciId  BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi       DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  olusturanKullanici Kullanici? @relation("SistemAyarVersiyonOlusturan", fields: [olusturanKullaniciId], references: [id])

  @@map("sistem_ayar_versiyon")
}

model SifrePolitikasi {
  id                    Int      @id @default(1)
  minUzunluk            Int      @default(10) @map("min_uzunluk")
  ozelKarakterZorunlu   Boolean  @default(true) @map("ozel_karakter_zorunlu")
  sayiZorunlu           Boolean  @default(true) @map("sayi_zorunlu")
  buyukKucukHarfZorunlu Boolean  @default(true) @map("buyuk_kucuk_harf_zorunlu")
  gecerlilikGun         Int      @default(90) @map("gecerlilik_gun")
  gecmisSifreSayisi     Int      @default(5) @map("gecmis_sifre_sayisi")
  maxYanlisGiris        Int      @default(5) @map("max_yanlis_giris")
  kilitDakika           Int      @default(15) @map("kilit_dakika")
  olusturmaTarihi       DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi      DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  @@map("sifre_politikasi")
}

model Kullanici {
  id                      BigInt    @id @default(autoincrement())
  publicId                String    @unique @default(uuid()) @map("public_id") @db.Uuid
  email                   String    @unique @db.Citext
  sifreHash               String    @map("sifre_hash") @db.VarChar(255)
  ad                      String    @db.VarChar(100)
  soyad                   String    @db.VarChar(100)
  telefon                 String?   @db.VarChar(30)
  avatarUrl               String?   @map("avatar_url") @db.Text
  dil                     String?   @db.Char(2)
  zamanDilimi             String?   @map("zaman_dilimi") @db.VarChar(50)
  ikiFaktorAktif          Boolean   @default(false) @map("iki_faktor_aktif")
  ikiFaktorSecret         Bytes?    @map("iki_faktor_secret")
  ikiFaktorYedekKodlar    String[]  @map("iki_faktor_yedek_kodlar")
  sifreSonDegisim         DateTime? @map("sifre_son_degisim") @db.Timestamptz(6)
  sifreSifirlamaTokeni    String?   @map("sifre_sifirlama_tokeni") @db.VarChar(100)
  sifreSifirlamaSon       DateTime? @map("sifre_sifirlama_son") @db.Timestamptz(6)
  yanlisGirisSayisi       Int       @default(0) @map("yanlis_giris_sayisi")
  kilitliSonTarih         DateTime? @map("kilitli_son_tarih") @db.Timestamptz(6)
  sonGirisTarihi          DateTime? @map("son_giris_tarihi") @db.Timestamptz(6)
  sonGirisIp              String?   @map("son_giris_ip") @db.Inet
  sonAktiviteTarihi       DateTime? @map("son_aktivite_tarihi") @db.Timestamptz(6)
  tercihler               Json      @default("{}") @db.JsonB
  aktifMi                 Boolean   @default(true) @map("aktif_mi")
  silindiMi               Boolean   @default(false) @map("silindi_mi")
  silinmeTarihi           DateTime? @map("silinme_tarihi") @db.Timestamptz(6)
  silenKullaniciId        BigInt?   @map("silen_kullanici_id")
  olusturanKullaniciId    BigInt?   @map("olusturan_kullanici_id")
  guncelleyenKullaniciId  BigInt?   @map("guncelleyen_kullanici_id")
  olusturmaTarihi         DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi        DateTime  @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  silenKullanici       Kullanici?  @relation("KullaniciSilen", fields: [silenKullaniciId], references: [id])
  olusturanKullanici   Kullanici?  @relation("KullaniciOlusturan", fields: [olusturanKullaniciId], references: [id])
  guncelleyenKullanici Kullanici?  @relation("KullaniciGuncelleyen", fields: [guncelleyenKullaniciId], references: [id])

  silenKullanicilar       Kullanici[] @relation("KullaniciSilen")
  olusturanKullanicilar   Kullanici[] @relation("KullaniciOlusturan")
  guncelleyenKullanicilar Kullanici[] @relation("KullaniciGuncelleyen")

  sifreGecmisleri           KullaniciSifreGecmisi[]
  roller                    KullaniciRol[]
  magazalar                 KullaniciMagaza[]
  oturumlar                 Oturum[]
  oturumAnomalileri         OturumAnomali[]
  bildirimler               Bildirim[]
  auditLoglar               AuditLog[]
  sistemAyarVersiyonlari    SistemAyarVersiyon[]         @relation("SistemAyarVersiyonOlusturan")
  ikiFaYedekKullanimlar     Kullanici2FaYedekKullanim[]

  @@map("kullanici")
}

model KullaniciSifreGecmisi {
  id              BigInt   @id @default(autoincrement())
  kullaniciId     BigInt   @map("kullanici_id")
  sifreHash       String   @map("sifre_hash") @db.VarChar(255)
  olusturmaTarihi DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_sifre_gecmisi")
}

model SifreSifirlamaTokeni {
  id                  BigInt    @id @default(autoincrement())
  kullaniciId         BigInt    @map("kullanici_id")
  tokenHash           String    @unique @map("token_hash") @db.VarChar(255)
  sonKullanimTarihi   DateTime  @map("son_kullanim_tarihi") @db.Timestamptz(6)
  kullanildiMi        Boolean   @default(false) @map("kullanildi_mi")
  kullanimTarihi      DateTime? @map("kullanim_tarihi") @db.Timestamptz(6)
  kullanimIp          String?   @map("kullanim_ip") @db.Inet
  olusturmaIp         String?   @map("olusturma_ip") @db.Inet
  olusturmaTarihi     DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  @@map("sifre_sifirlama_tokeni")
}

model Kullanici2FaYedekKullanim {
  id              BigInt   @id @default(autoincrement())
  kullaniciId     BigInt   @map("kullanici_id")
  kodHash         String   @map("kod_hash") @db.VarChar(255)
  kullanimTarihi  DateTime @default(now()) @map("kullanim_tarihi") @db.Timestamptz(6)
  kullanimIp      String?  @map("kullanim_ip") @db.Inet
  cihazBilgisi    String?  @map("cihaz_bilgisi") @db.Text
  olusturmaTarihi DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("kullanici_2fa_yedek_kullanim")
}

model Rol {
  id                      BigInt   @id @default(autoincrement())
  kod                     String   @unique @db.VarChar(50)
  ad                      String   @db.VarChar(100)
  aciklama                String?  @db.Text
  sistemRoluMu            Boolean  @default(false) @map("sistem_rolu_mu")
  olusturanKullaniciId    BigInt?  @map("olusturan_kullanici_id")
  guncelleyenKullaniciId  BigInt?  @map("guncelleyen_kullanici_id")
  olusturmaTarihi         DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi        DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  yetkiler       RolYetki[]
  kullanicilar   KullaniciRol[]
  yetkiKapsamlar YetkiKapsam[]

  @@map("rol")
}

model Yetki {
  id              BigInt   @id @default(autoincrement())
  kod             String   @unique @db.VarChar(100)
  modul           String   @db.VarChar(50)
  eylem           String   @db.VarChar(50)
  ad              String   @db.VarChar(200)
  aciklama        String?  @db.Text
  riskliMi        Boolean  @default(false) @map("riskli_mi")
  olusturmaTarihi DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  roller         RolYetki[]
  yetkiKapsamlar YetkiKapsam[]

  @@map("yetki")
}

model RolYetki {
  rolId                BigInt   @map("rol_id")
  yetkiId              BigInt   @map("yetki_id")
  olusturanKullaniciId BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  rol   Rol   @relation(fields: [rolId], references: [id], onDelete: Cascade)
  yetki Yetki @relation(fields: [yetkiId], references: [id], onDelete: Cascade)

  @@id([rolId, yetkiId])
  @@map("rol_yetki")
}

model YetkiKapsam {
  id                   BigInt   @id @default(autoincrement())
  rolId                BigInt   @map("rol_id")
  yetkiId              BigInt   @map("yetki_id")
  kapsamTipi           String   @map("kapsam_tipi") @db.VarChar(30)
  kapsamJsonb          Json     @default("{}") @map("kapsam_jsonb") @db.JsonB
  olusturanKullaniciId BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  rol   Rol   @relation(fields: [rolId], references: [id], onDelete: Cascade)
  yetki Yetki @relation(fields: [yetkiId], references: [id], onDelete: Cascade)

  @@unique([rolId, yetkiId, kapsamTipi])
  @@map("yetki_kapsam")
}

model KullaniciRol {
  kullaniciId          BigInt    @map("kullanici_id")
  rolId                BigInt    @map("rol_id")
  aktifBaslangic       DateTime? @map("aktif_baslangic") @db.Date
  aktifBitis           DateTime? @map("aktif_bitis") @db.Date
  olusturanKullaniciId BigInt?   @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  rol       Rol       @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([kullaniciId, rolId])
  @@map("kullanici_rol")
}

model KullaniciMagaza {
  kullaniciId          BigInt   @map("kullanici_id")
  magazaId             BigInt   @map("magaza_id")
  varsayilanMi         Boolean  @default(false) @map("varsayilan_mi")
  olusturanKullaniciId BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  magaza    Magaza    @relation(fields: [magazaId], references: [id], onDelete: Cascade)

  @@id([kullaniciId, magazaId])
  @@map("kullanici_magaza")
}

model Oturum {
  id                  BigInt    @id @default(autoincrement())
  publicId            String    @unique @default(uuid()) @map("public_id") @db.Uuid
  kullaniciId         BigInt    @map("kullanici_id")
  refreshTokenHash    String    @unique @map("refresh_token_hash") @db.VarChar(255)
  cihazBilgisi        String?   @map("cihaz_bilgisi") @db.Text
  cihazTipi           String?   @map("cihaz_tipi") @db.VarChar(20)
  cihazParmakIzi      String?   @map("cihaz_parmak_izi") @db.VarChar(255)
  tarayici            String?   @db.VarChar(50)
  isletimSistemi      String?   @map("isletim_sistemi") @db.VarChar(50)
  olusturmaIp         String?   @map("olusturma_ip") @db.Inet
  sonKullanimIp       String?   @map("son_kullanim_ip") @db.Inet
  konumUlke           String?   @map("konum_ulke") @db.Char(2)
  konumSehir          String?   @map("konum_sehir") @db.VarChar(100)
  riskSkoru           Int       @default(0) @map("risk_skoru") @db.SmallInt
  olusturmaTarihi     DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  sonKullanimTarihi   DateTime  @default(now()) @map("son_kullanim_tarihi") @db.Timestamptz(6)
  sonKullanimBitis    DateTime  @map("son_kullanim_bitis") @db.Timestamptz(6)
  iptalEdildiMi       Boolean   @default(false) @map("iptal_edildi_mi")
  iptalTarihi         DateTime? @map("iptal_tarihi") @db.Timestamptz(6)
  iptalNedeni         String?   @map("iptal_nedeni") @db.VarChar(100)

  kullanici  Kullanici       @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  anomaliler OturumAnomali[]

  @@map("oturum")
}

model OturumAnomali {
  id              BigInt   @id @default(autoincrement())
  oturumId        BigInt   @map("oturum_id")
  kullaniciId     BigInt   @map("kullanici_id")
  anomaliTipi     String   @map("anomali_tipi") @db.VarChar(30)
  eskiDeger       String?  @map("eski_deger") @db.Text
  yeniDeger       String?  @map("yeni_deger") @db.Text
  riskSkoru       Int      @default(0) @map("risk_skoru") @db.SmallInt
  aksiyon         String?  @db.VarChar(30)
  olusturmaTarihi DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  oturum    Oturum    @relation(fields: [oturumId], references: [id], onDelete: Cascade)
  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@map("oturum_anomali")
}

model ApiAnahtar {
  id                      BigInt    @id @default(autoincrement())
  publicId                String    @unique @default(uuid()) @map("public_id") @db.Uuid
  ad                      String    @db.VarChar(200)
  aciklama                String?   @db.Text
  anahtarHash             String    @unique @map("anahtar_hash") @db.VarChar(255)
  onEk                    String    @map("on_ek") @db.VarChar(20)
  yetkiler                String[]  @default([])
  izinVerilenIp           String[]  @map("izin_verilen_ip")
  rateLimitDakika         Int?      @map("rate_limit_dakika")
  rateLimitGun            Int?      @map("rate_limit_gun")
  olusturanKullaniciId    BigInt?   @map("olusturan_kullanici_id")
  sonKullanimTarihi       DateTime? @map("son_kullanim_tarihi") @db.Timestamptz(6)
  sonKullanimIp           String?   @map("son_kullanim_ip") @db.Inet
  sonKullanimBitis        DateTime? @map("son_kullanim_bitis") @db.Timestamptz(6)
  iptalEdildiMi           Boolean   @default(false) @map("iptal_edildi_mi")
  iptalTarihi             DateTime? @map("iptal_tarihi") @db.Timestamptz(6)
  olusturmaTarihi         DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  rateLimitler ApiRateLimit[]

  @@map("api_anahtar")
}

model ApiRateLimit {
  id               BigInt   @id @default(autoincrement())
  apiAnahtarId     BigInt   @map("api_anahtar_id")
  pencereBaslangic DateTime @map("pencere_baslangic") @db.Timestamptz(6)
  pencereTipi      String   @map("pencere_tipi") @db.VarChar(10)
  istekSayisi      Int      @default(0) @map("istek_sayisi")
  sonIstekZamani   DateTime @default(now()) @map("son_istek_zamani") @db.Timestamptz(6)

  apiAnahtar ApiAnahtar @relation(fields: [apiAnahtarId], references: [id], onDelete: Cascade)

  @@unique([apiAnahtarId, pencereTipi, pencereBaslangic])
  @@map("api_rate_limit")
}

model BelgeNumaraSerisi {
  id                   BigInt   @id @default(autoincrement())
  belgeTipi            String   @map("belge_tipi") @db.VarChar(30)
  firmaId              BigInt?  @map("firma_id")
  magazaId             BigInt?  @map("magaza_id")
  yil                  Int?
  onEk                 String   @default("") @map("on_ek") @db.VarChar(20)
  sonEk                String   @default("") @map("son_ek") @db.VarChar(20)
  uzunluk              Int      @default(6) @db.SmallInt
  sonraki              BigInt   @default(1)
  aciklama             String?  @db.Text
  aktifMi              Boolean  @default(true) @map("aktif_mi")
  olusturanKullaniciId BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi     DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  firma  Firma?  @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  magaza Magaza? @relation(fields: [magazaId], references: [id], onDelete: Cascade)

  @@unique([belgeTipi, firmaId, magazaId, yil])
  @@map("belge_numara_serisi")
}

model AuditLog {
  id              BigInt   @default(autoincrement())
  kullaniciId     BigInt?  @map("kullanici_id")
  apiAnahtarId    BigInt?  @map("api_anahtar_id")
  oturumId        BigInt?  @map("oturum_id")
  eylem           String   @db.VarChar(50)
  yetkiKodu       String?  @map("yetki_kodu") @db.VarChar(100)
  tabloAdi        String?  @map("tablo_adi") @db.VarChar(100)
  kayitId         BigInt?  @map("kayit_id")
  eskiVeri        Json?    @map("eski_veri") @db.JsonB
  yeniVeri        Json?    @map("yeni_veri") @db.JsonB
  degisimAlanlari String[] @map("degisim_alanlari")
  aciklama        String?  @db.Text
  ipAdresi        String?  @map("ip_adresi") @db.Inet
  cihazBilgisi    String?  @map("cihaz_bilgisi") @db.Text
  basariliMi      Boolean  @default(true) @map("basarili_mi")
  hataMesaji      String?  @map("hata_mesaji") @db.Text
  olusturmaTarihi DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  kullanici Kullanici? @relation(fields: [kullaniciId], references: [id])

  @@id([id, olusturmaTarihi])
  @@map("audit_log")
}

model BildirimTipi {
  id                  BigInt   @id @default(autoincrement())
  kod                 String   @unique @db.VarChar(50)
  ad                  String   @db.VarChar(200)
  aciklama            String?  @db.Text
  varsayilanKanallar  String[] @default(["in_app"]) @map("varsayilan_kanallar")
  sablonKod           String?  @map("sablon_kod") @db.VarChar(100)
  ikon                String?  @db.VarChar(50)
  renk                String?  @db.VarChar(20)
  seviye              String   @default("bilgi") @db.VarChar(20)
  aktifMi             Boolean  @default(true) @map("aktif_mi")
  olusturmaTarihi     DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi    DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  bildirimler Bildirim[]

  @@map("bildirim_tipi")
}

model Bildirim {
  id              BigInt    @id @default(autoincrement())
  kullaniciId     BigInt    @map("kullanici_id")
  bildirimTipiId  BigInt?   @map("bildirim_tipi_id")
  tipKod          String    @map("tip_kod") @db.VarChar(50)
  seviye          String    @default("bilgi") @db.VarChar(20)
  baslik          String    @db.VarChar(200)
