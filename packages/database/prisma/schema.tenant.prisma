  publicId              String    @unique @default(uuid()) @map("public_id") @db.Uuid
  kod                   String    @unique @db.VarChar(50)
  ad                    String    @db.VarChar(200)
  aciklama              String?   @db.Text
  paraBirimiKod         String    @map("para_birimi_kod") @db.Char(3)
  fiyatlarKdvDahilMi    Boolean   @default(true) @map("fiyatlar_kdv_dahil_mi")
  tip                   String    @default("sabit") @db.VarChar(30)
  kaynakFiyatListesiId  BigInt?   @map("kaynak_fiyat_listesi_id")
  iskontoOrani          Decimal?  @map("iskonto_orani") @db.Decimal(7, 4)
  iskontoTutar          Decimal?  @map("iskonto_tutar") @db.Decimal(18, 4)
  gecerliBaslangic      DateTime? @map("gecerli_baslangic") @db.Timestamptz(6)
  gecerliBitis          DateTime? @map("gecerli_bitis") @db.Timestamptz(6)
  varsayilanMi          Boolean   @default(false) @map("varsayilan_mi")
  aktifMi               Boolean   @default(true) @map("aktif_mi")
  silindiMi             Boolean   @default(false) @map("silindi_mi")
  olusturmaTarihi       DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi      DateTime  @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  kaynakFiyatListesi FiyatListesi?  @relation("FiyatListesiKaynak", fields: [kaynakFiyatListesiId], references: [id])
  turetilmisListeler FiyatListesi[] @relation("FiyatListesiKaynak")

  varyantFiyatlar FiyatListesiVaryant[]
  magazalar       Magaza[]
  cariGrupler     CariGrup[]
  cariler         Cari[]

  @@map("fiyat_listesi")
}

model FiyatListesiVaryant {
  id                  BigInt   @id @default(autoincrement())
  fiyatListesiId      BigInt   @map("fiyat_listesi_id")
  urunVaryantId       BigInt   @map("urun_varyant_id")
  fiyat               Decimal  @db.Decimal(18, 4)
  listeFiyati         Decimal? @map("liste_fiyati") @db.Decimal(18, 4)
  indirimliFiyat      Decimal? @map("indirimli_fiyat") @db.Decimal(18, 4)
  indirimliBaslangic  DateTime? @map("indirimli_baslangic") @db.Timestamptz(6)
  indirimliBitis      DateTime? @map("indirimli_bitis") @db.Timestamptz(6)
  minimumMiktar       Decimal  @default(1) @map("minimum_miktar") @db.Decimal(15, 4)
  olusturmaTarihi     DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi    DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  fiyatListesi FiyatListesi @relation(fields: [fiyatListesiId], references: [id], onDelete: Cascade)
  urunVaryant  UrunVaryant  @relation(fields: [urunVaryantId], references: [id], onDelete: Cascade)

  @@unique([fiyatListesiId, urunVaryantId, minimumMiktar])
  @@map("fiyat_listesi_varyant")
}

model UrunFiyatGecmis {
  id                     BigInt   @id @default(autoincrement())
  urunVaryantId          BigInt   @map("urun_varyant_id")
  fiyatListesiId         BigInt?  @map("fiyat_listesi_id")
  eskiFiyat              Decimal? @map("eski_fiyat") @db.Decimal(18, 4)
  yeniFiyat              Decimal  @map("yeni_fiyat") @db.Decimal(18, 4)
  paraBirimiKod          String   @map("para_birimi_kod") @db.Char(3)
  sebep                  String?  @db.VarChar(200)
  degistirenKullaniciId  BigInt?  @map("degistiren_kullanici_id")
  olusturmaTarihi        DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  urunVaryant UrunVaryant @relation(fields: [urunVaryantId], references: [id], onDelete: Cascade)

  @@map("urun_fiyat_gecmis")
}

