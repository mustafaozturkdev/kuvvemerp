  guncelleyenKullaniciId  BigInt?   @map("guncelleyen_kullanici_id")
  olusturmaTarihi         DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi        DateTime  @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  sablonlar   BildirimSablon[]
  gonderimler BildirimGonderim[]

  @@map("bildirim_provider")
}

model BildirimSablon {
  id                   BigInt   @id @default(autoincrement())
  publicId             String   @unique @default(uuid()) @map("public_id") @db.Uuid
  kod                  String   @db.VarChar(100)
  ad                   String   @db.VarChar(200)
  aciklama             String?  @db.Text
  tip                  String   @db.VarChar(20)
  dilKodu              String   @default("tr") @map("dil_kodu") @db.Char(2)
  konu                 String?  @db.VarChar(500)
  icerikHtml           String?  @map("icerik_html") @db.Text
  icerikText           String?  @map("icerik_text") @db.Text
  degiskenListesi      String[] @default([]) @map("degisken_listesi")
  ornekVeri            Json?    @map("ornek_veri") @db.JsonB
  providerId           BigInt?  @map("provider_id")
  kategori             String?  @db.VarChar(50)
  pazarlamaMi          Boolean  @default(false) @map("pazarlama_mi")
  aktifMi              Boolean  @default(true) @map("aktif_mi")
  silindiMi            Boolean  @default(false) @map("silindi_mi")
  olusturanKullaniciId BigInt?  @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi     DateTime @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  provider BildirimProvider? @relation(fields: [providerId], references: [id])

  @@unique([kod, tip, dilKodu])
  @@map("bildirim_sablon")
}

model BildirimGonderim {
  id                   BigInt    @id @default(autoincrement())
  publicId             String    @unique @default(uuid()) @map("public_id") @db.Uuid
  providerId           BigInt    @map("provider_id")
  sablonId             BigInt?   @map("sablon_id")
  tip                  String    @db.VarChar(20)
  cariId               BigInt?   @map("cari_id")
  kullaniciId          BigInt?   @map("kullanici_id")
  alici                String    @db.VarChar(500)
  konu                 String?   @db.VarChar(500)
  icerik               String?   @db.Text
  degiskenDegerler     Json?     @map("degisken_degerler") @db.JsonB
  kaynakBelgeTipi      String?   @map("kaynak_belge_tipi") @db.VarChar(50)
  kaynakBelgeId        BigInt?   @map("kaynak_belge_id")
  durum                String    @default("kuyrukta") @db.VarChar(20)
  gonderimZamani       DateTime? @map("gonderim_zamani") @db.Timestamptz(6)
  teslimZamani         DateTime? @map("teslim_zamani") @db.Timestamptz(6)
  okunmaZamani         DateTime? @map("okunma_zamani") @db.Timestamptz(6)
  providerMesajId      String?   @map("provider_mesaj_id") @db.VarChar(200)
  hataMesaji           String?   @map("hata_mesaji") @db.Text
  providerResponse     Json?     @map("provider_response") @db.JsonB
  birimUcret           Decimal?  @map("birim_ucret") @db.Decimal(10, 4)
  paraBirimiKod        String?   @map("para_birimi_kod") @db.Char(3)
  olusturanKullaniciId BigInt?   @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  provider BildirimProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@map("bildirim_gonderim")
}

model EfaturaKuyruk {
  id                   BigInt    @id @default(autoincrement())
  publicId             String    @unique @default(uuid()) @map("public_id") @db.Uuid
  faturaId             BigInt    @unique @map("fatura_id")
  senaryo              String    @default("TEMELFATURA") @db.VarChar(20)
  durum                String    @default("bekliyor") @db.VarChar(20)
  denemeSayisi         Int       @default(0) @map("deneme_sayisi")
  maksimumDeneme       Int       @default(5) @map("maksimum_deneme")
  sonDeneme            DateTime? @map("son_deneme") @db.Timestamptz(6)
  sonrakiDeneme        DateTime? @map("sonraki_deneme") @db.Timestamptz(6)
  hataMesaji           String?   @map("hata_mesaji") @db.Text
  gibUuid              String?   @map("gib_uuid") @db.VarChar(100)
  gibEnvanterNo        String?   @map("gib_envanter_no") @db.VarChar(100)
  gibGonderimZamani    DateTime? @map("gib_gonderim_zamani") @db.Timestamptz(6)
  gibCevapZamani       DateTime? @map("gib_cevap_zamani") @db.Timestamptz(6)
  gibResponse          Json?     @map("gib_response") @db.JsonB
  ublXml               String?   @map("ubl_xml") @db.Text
  pdfUrl               String?   @map("pdf_url") @db.Text
  aliciVergiNo         String?   @map("alici_vergi_no") @db.VarChar(50)
  aliciEtiket          String?   @map("alici_etiket") @db.VarChar(200)
  olusturanKullaniciId BigInt?   @map("olusturan_kullanici_id")
  olusturmaTarihi      DateTime  @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)
  guncellemeTarihi     DateTime  @updatedAt @map("guncelleme_tarihi") @db.Timestamptz(6)

  @@map("efatura_kuyruk")
}

model EfaturaMukellef {
  id                      BigInt   @id @default(autoincrement())
  vergiNo                 String   @unique @map("vergi_no") @db.VarChar(50)
  unvan                   String?  @db.VarChar(500)
  eFaturaMukellefMi       Boolean  @default(false) @map("e_fatura_mukellef_mi")
  eFaturaEtiket           String?  @map("e_fatura_etiket") @db.VarChar(300)
  eArsivMukellefMi        Boolean  @default(false) @map("e_arsiv_mukellef_mi")
  eIrsaliyeMukellefMi     Boolean  @default(false) @map("e_irsaliye_mukellef_mi")
  eFaturaBaslangic        DateTime? @map("e_fatura_baslangic") @db.Date
  adres                   String?  @db.Text
  il                      String?  @db.VarChar(100)
  ilce                    String?  @db.VarChar(100)
  postaKodu               String?  @map("posta_kodu") @db.VarChar(20)
  sonGuncelleme           DateTime @default(now()) @map("son_guncelleme") @db.Timestamptz(6)
  kaynak                  String   @default("GIB") @db.VarChar(50)
  olusturmaTarihi         DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  @@map("efatura_mukellef")
}

model ApiCagriLog {
  id                BigInt   @default(autoincrement())
  publicId          String   @default(uuid()) @map("public_id") @db.Uuid
  servisKod         String   @map("servis_kod") @db.VarChar(50)
  endpoint          String   @db.VarChar(500)
  httpMethod        String   @map("http_method") @db.VarChar(10)
  istekHeaderlar    Json?    @map("istek_headerlar") @db.JsonB
  istekPayload      Json?    @map("istek_payload") @db.JsonB
  istekBoyutByte    Int?     @map("istek_boyut_byte")
  httpStatus        Int?     @map("http_status")
  responseBody      String?  @map("response_body") @db.Text
  responseBoyutByte Int?     @map("response_boyut_byte")
  sureMs            Int?     @map("sure_ms")
  hata              Boolean  @default(false)
  hataMesaji        String?  @map("hata_mesaji") @db.Text
  retrySayisi       Int      @default(0) @map("retry_sayisi")
  kaynakBelgeTipi   String?  @map("kaynak_belge_tipi") @db.VarChar(50)
  kaynakBelgeId     BigInt?  @map("kaynak_belge_id")
  kullaniciId       BigInt?  @map("kullanici_id")
  ipAdresi          String?  @map("ip_adresi") @db.Inet
  olusturmaTarihi   DateTime @default(now()) @map("olusturma_tarihi") @db.Timestamptz(6)

  @@id([id, olusturmaTarihi])
  @@map("api_cagri_log")
}

