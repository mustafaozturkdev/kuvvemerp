  id                BigInt    @id @default(autoincrement())
  eventId           BigInt    @map("event_id")
  endpointId        BigInt    @map("endpoint_id")
  denemeSirasi      Int       @default(1) @map("deneme_sirasi")
  istekUrl          String    @map("istek_url") @db.Text
  istekHeaderlar    Json?     @map("istek_headerlar") @db.JsonB
  istekBody         String?   @map("istek_body") @db.Text
