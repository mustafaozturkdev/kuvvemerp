NODE_ENV=development
PORT=4000

# Master DB
DATABASE_URL_MASTER="postgresql://kuvvem_app:devpass@localhost:5432/kuvvem_master"

# Tenant DB template ({db} placeholder — tenant.db_adi yerine geçirilir)
DATABASE_URL_TEMPLATE="postgresql://kuvvem_app:devpass@localhost:5432/{db}"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars-long-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# Argon2id parametreleri
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# Tenant LRU cache
TENANT_CACHE_MAX=80
TENANT_CACHE_TTL_MS=600000

# Log
LOG_LEVEL=info
